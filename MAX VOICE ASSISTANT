import speech_recognition as sr
import pyttsx3
import wikipedia
import webbrowser
import datetime
import os
import pywhatkit
import requests
import threading


from openai import OpenAI
client = OpenAI(api_key="YOUR API")

from kivy.app import App
from kivy.uix.button import Button
from kivy.uix.label import Label
from kivy.uix.boxlayout import BoxLayout


engine = pyttsx3.init()

chat_history = []

def speak(text):
    print("MAX:", text)
    engine.say(text)
    engine.runAndWait()


def wish():
    hour = int(datetime.datetime.now().hour)

    if hour < 12:
        speak("Good Morning")
    elif hour < 18:
        speak("Good Afternoon")
    else:
        speak("Good Evening")

    speak("I am MAX, your personal assistant. Say Hey Max to wake me up.")


def take_command():
    r = sr.Recognizer()

    with sr.Microphone() as source:
        print("Listening...")
        r.pause_threshold = 1
        try:
            audio = r.listen(source, timeout=5, phrase_time_limit=5)
        except:
            return ""

    try:
        command = r.recognize_google(audio)
        print("You said:", command)
        return command.lower()
    except:
        return ""

def chat_with_ai(prompt):
    try:
        chat_history.append({"role": "user", "content": prompt})

        response = client.chat.completions.create(
            model="gpt-4o-mini",
            messages=chat_history
        )

        reply = response.choices[0].message.content
        chat_history.append({"role": "assistant", "content": reply})

        return reply

    except Exception as e:
        print("AI ERROR:", e)
        return "Sorry, I am having trouble connecting right now."

def process_command(command):
    if "time" in command:
        time = datetime.datetime.now().strftime("%H:%M")
        speak("The time is " + time)

    elif "wikipedia" in command:
        speak("Searching Wikipedia")
        query = command.replace("wikipedia", "")

        try:
            result = wikipedia.summary(query, sentences=2)
            speak(result)
        except:
            speak("I could not find information")

    elif "open youtube" in command:
        webbrowser.open("https://www.youtube.com")
        speak("Opening YouTube")

    elif "open google" in command:
        webbrowser.open("https://www.google.com")
        speak("Opening Google")

    elif "search google" in command:
        speak("What should I search?")
        search = take_command()
        webbrowser.open("https://www.google.com/search?q=" + search)

    elif "play" in command:
        speak("Which song should I play?")
        song = take_command()

        if song != "":
            pywhatkit.playonyt(song)
            speak("Playing " + song)
        else:
            speak("I did not catch the song name")

    elif "calculate" in command:
        speak("What should I calculate?")
        expression = take_command()

        try:
            result = eval(expression)
            speak("The answer is " + str(result))
        except:
            speak("Sorry, I could not calculate that")

    elif "weather" in command:
        try:
            if "in" in command:
                city = command.split("in")[1].strip()
            else:
                speak("Please tell the city name")
                city = take_command()

            speak("Getting weather report for " + city)

            api_key = "9a6267bac80b9e4329ec17925662e9cc"

            url = f"https://api.openweathermap.org/data/2.5/weather?q={city},IN&appid={api_key}&units=metric"

            response = requests.get(url)
            data = response.json()

            if response.status_code == 200:
                temp = data["main"]["temp"]
                description = data["weather"][0]["description"]

                result = f"The temperature in {city} is {temp} degree Celsius with {description}"
                speak(result)
            else:
                speak("City not found")

        except:
            speak("Sorry I could not get the weather report")

    elif "open chrome" in command:
        os.startfile("C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe")

    elif "open notepad" in command:
        os.system("notepad")

    elif "exit" in command or "stop" in command:
        speak("Goodbye")

    else:
        
        reply = chat_with_ai(command)
        speak(reply)


def listen_for_wake_word(app):
    while True:
        print("Waiting for wake word...")

        command = take_command()

        if command == "":
            continue

        print("Heard:", command)

        if "max" in command:
            print("Wake word detected!")

            app.label.text = "max detected!"
            speak("Yes, I am listening")

            
            while True:
                command = take_command()

                if command == "":
                    continue

                print("Command:", command)
                app.label.text = "You said: " + command

                if "stop" in command or "exit" in command:
                    speak("Going back to sleep")
                    break

                process_command(command)




class MaxApp(App):
    def build(self):
        layout = BoxLayout(orientation='vertical')

        self.label = Label(text="Say 'Hey Max' or press 🎤")
        btn = Button(text="🎤 Speak")

        btn.bind(on_press=self.start_listening)

        layout.add_widget(self.label)
        layout.add_widget(btn)

        wish()

        threading.Thread(target=listen_for_wake_word, args=(self,), daemon=True).start()

        return layout

    def start_listening(self, instance):
        threading.Thread(target=self.run_max).start()

    def run_max(self):
        self.label.text = "Listening..."
        command = take_command()

        if command != "":
            self.label.text = "You said: " + command
            process_command(command)
        else:
            self.label.text = "Didn't catch that"



MaxApp().run()

